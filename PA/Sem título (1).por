programa {
  funcao inicio() {
    real salario_mensal, salario_diario, dias_trabalhados

    escreva("Informe o salário mensal: ")
    leia(salario_mensal)
    escreva("quais são as suas quantidade de dias trabalhados: ")
    leia(dias_trabalhados)

    salario_diario=salario_mensal/dias_trabalhados

    escreva("O seu salário diário é: ", salario_diario)

  }
}
