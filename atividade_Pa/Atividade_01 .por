programa {
  funcao inicio() {
    real valor1, valor2, valor3, soma

    escreva("Informe o valor 1: ")
    leia(valor1)
    escreva("Informe o valor 2: ")
    leia(valor2)
    escreva("Informe o valor 3: ")
    leia(valor3)

    soma = (valor1 + valor2 + valor3)

    escreva("A soma dos números é: ", soma)

  }
}
